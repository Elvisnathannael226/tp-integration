      "title": "Top 5 catégories de tickets",
      "type": "barchart",
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "glpi-mysql"
          },
          "format": "table",
          "rawSql": "SELECT\n  COALESCE(ic.name, 'Sans catégorie') AS categorie,\n  COUNT(t.id) AS nombre\nFROM glpi_tickets t\nLEFT JOIN glpi_itilcategories ic ON ic.id = t.itilcategories_id\nGROUP BY ic.name\nORDER BY nombre DESC\nLIMIT 5;",
          "refId": "A"
        }
