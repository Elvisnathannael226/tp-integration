      "title": "Tickets récents (20 derniers)",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "glpi-mysql"
          },
          "format": "table",
          "rawSql": "SELECT\n  t.id AS `ID`,\n  t.name AS `Titre`,\n  t.status AS `Statut`,\n  DATE(t.date_creation) AS `Date création`,\n  t.priority AS `Priorité`\nFROM glpi_tickets t\nORDER BY t.date_creation DESC\nLIMIT 20;",
          "refId": "A"
        }
      ]
