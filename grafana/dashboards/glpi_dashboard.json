      "title": "Répartition des tickets par statut",
      "type": "piechart",
      "targets": [
        {
          "datasource": {
            "type": "mysql",
            "uid": "glpi-mysql"
          },
          "format": "table",
          "rawSql": "SELECT\n  CASE status\n    WHEN 1 THEN 'Nouveau'\n    WHEN 2 THEN 'En cours (attribué)'\n    WHEN 3 THEN 'En cours (planifié)'\n    WHEN 4 THEN 'En attente'\n    WHEN 5 THEN 'Résolu'\n    WHEN 6 THEN 'Clos'\n    ELSE 'Inconnu'\n  END AS statut,\n  COUNT(*) AS nombre\nFROM glpi_tickets\nGROUP BY status\nORDER BY status;",
          "refId": "A"
        }
      ]
    },
