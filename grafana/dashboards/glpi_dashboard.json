          "format": "time_series",
          "rawSql": "SELECT\n  DATE(date_creation) AS time,\n  COUNT(*) AS `Tickets créés`\nFROM glpi_tickets\nWHERE date_creation >= DATE_SUB(NOW(), INTERVAL 30 DAY)\nGROUP BY DATE(date_creation)\nORDER BY DATE(date_creation);",
